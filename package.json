{
  "name": "sigsum",
  "version": "0.0.0",
  "description": "Fast file hashing with BLAKE3. Native Rust speed for duplicate detection, integrity checks, and content addressing.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "native.cjs",
    "native.d.cts",
    "index.d.ts",
    "sigsum.*.node"
  ],
  "scripts": {
    "build:rs": "napi build --platform --release && mv index.js native.cjs",
    "build:ts": "tsup",
    "build": "pnpm build:rs && pnpm build:ts",
    "dev": "napi build --platform && mv index.js native.cjs && pnpm build:ts",
    "test": "vitest run",
    "bench": "vitest bench",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format:rs": "cargo fmt --check",
    "clippy": "cargo clippy -- -D warnings",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version"
  },
  "napi": {
    "binaryName": "sigsum",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "keywords": [
    "blake3",
    "hash",
    "file-hash",
    "checksum",
    "duplicate-detection",
    "content-addressing",
    "integrity",
    "native",
    "napi"
  ],
  "author": "Sigge",
  "license": "MIT",
  "sideEffects": false,
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "optionalDependencies": {
    "sigsum-darwin-arm64": "0.0.0",
    "sigsum-darwin-x64": "0.0.0",
    "sigsum-linux-arm64-gnu": "0.0.0",
    "sigsum-linux-arm64-musl": "0.0.0",
    "sigsum-linux-x64-gnu": "0.0.0",
    "sigsum-linux-x64-musl": "0.0.0",
    "sigsum-win32-x64-msvc": "0.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@napi-rs/cli": "^3.5.1",
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
